{
  "name": "kemono-peruse",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
  "dev": "vite",
  "build": "vite build",
  "lint": "eslint .",
  "preview": "vite preview",
  "proxy": "node ../proxy-server.js",
  "dev:all": "concurrently \"npm run proxy\" \"npm run dev\"",
  "host:all": "concurrently \"npm run proxy\" \"npx vite --host\"",
  "preview:all": "concurrently \"npm run proxy\" \"npm run preview\""
},
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "vite": "^7.1.2"
  }
}
